# task1_data_collection.py
# TrendPulse - Task 1
# Fetch trending stories from HackerNews API and group them into categories

import requests
import json
import os
import time
from datetime import datetime

# Add request headers
headers = {"User-Agent": "TrendPulse/1.0"}

# API endpoints
TOP_STORIES_URL = "https://hacker-news.firebaseio.com/v0/topstories.json"
ITEM_URL = "https://hacker-news.firebaseio.com/v0/item/{}.json"

# Category keywords
categories = {
    "technology": [
        "ai", "software", "tech", "code", "computer",
        "data", "cloud", "api", "gpu", "llm"
    ],
    "worldnews": [
        "war", "government", "country", "president",
        "election", "climate", "attack", "global"
    ],
    "sports": [
        "nfl", "nba", "fifa", "sport", "game",
        "team", "player", "league", "championship"
    ],
    "science": [
        "research", "study", "space", "physics",
        "biology", "discovery", "nasa", "genome"
    ],
    "entertainment": [
        "movie", "film", "music", "netflix", "game",
        "book", "show", "award", "streaming"
    ]
}

# Maximum stories per category
MAX_PER_CATEGORY = 25


def get_category(title):
    """Assign category based on title keywords."""
    title_lower = title.lower()

    for category, keywords in categories.items():
        for keyword in keywords:
            if keyword.lower() in title_lower:
                return category

    return None


def fetch_json(url):
    """Fetch JSON data safely from API."""
    try:
        response = requests.get(url, headers=headers)
        response.raise_for_status()
        return response.json()
    except Exception as e:
        print(f"Request failed for {url}: {e}")
        return None


def main():
    # Create data folder if not exists
    os.makedirs("data", exist_ok=True)

    # Fetch top 500 story IDs
    top_story_ids = fetch_json(TOP_STORIES_URL)

    if not top_story_ids:
        print("Could not fetch top stories.")
        return

    top_story_ids = top_story_ids[:500]

    collected_stories = []
    category_counts = {cat: 0 for cat in categories}

    # Loop category-wise
    for category in categories:

        print(f"Collecting {category} stories...")

        for story_id in top_story_ids:

            # Stop after 25 stories per category
            if category_counts[category] >= MAX_PER_CATEGORY:
                break

            story = fetch_json(ITEM_URL.format(story_id))

            if not story:
                continue

            title = story.get("title", "")

            if not title:
                continue

            assigned_category = get_category(title)

            # Keep only matching category
            if assigned_category == category:

                story_data = {
                    "post_id": story.get("id"),
                    "title": title,
                    "category": assigned_category,
                    "score": story.get("score", 0),
                    "num_comments": story.get("descendants", 0),
                    "author": story.get("by", "unknown"),
                    "collected_at": datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                }

                collected_stories.append(story_data)
                category_counts[category] += 1

        # Sleep 2 seconds after each category
        time.sleep(2)

    # Save to JSON file
    file_date = datetime.now().strftime("%Y%m%d")
    filename = f"data/trends_{file_date}.json"

    with open(filename, "w", encoding="utf-8") as file:
        json.dump(collected_stories, file, indent=4)

    print(f"Collected {len(collected_stories)} stories. Saved to {filename}")


if __name__ == "__main__":
    main()
